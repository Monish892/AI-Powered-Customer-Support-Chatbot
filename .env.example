
# Flask Environment
# Use 'development' for debugging features, 'production' for live deployment
FLASK_ENV=development

# A secret key is required for session management and other security-related features
# Generate a secure random key. Example: python -c 'import secrets; print(secrets.token_hex(24))'
SECRET_KEY='your_super_secret_key_here'

# Database Connection String
# Format: 'dialect+driver://username:password@host:port/database'
# For this project, we use 'mysql+pymysql'
DATABASE_URL='mysql+pymysql://root:password@127.0.0.1:3306/chatbot_db'
